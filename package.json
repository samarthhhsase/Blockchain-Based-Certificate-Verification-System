{
  "name": "certificate-blockchain-system",
  "version": "3.0.0",
  "description": "Role-based blockchain certificate management with React, Express, MySQL, Hardhat, ethers.js, and Ganache.",
  "main": "backend/server.js",
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js --network ganache",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "client": "npm run dev --prefix frontend",
    "client:install": "npm install --prefix frontend",
    "client:dev": "npm run dev --prefix frontend",
    "client:build": "npm run build --prefix frontend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "react-router-dom": "^7.13.1",
    "svg-to-pdfkit": "^0.1.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "hardhat": "^2.28.6",
    "nodemon": "^3.1.4"
  }
}
